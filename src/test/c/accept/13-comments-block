/* Ecosistema con comentarios de bloque - valida que comentarios se ignoran correctamente */

/*
 * Definicion de una especie carnivora depredadora
 * Los atributos definen caracteristicas ecologicas clave
 */
species Puma = createSpecies {
    int lifespan = 15;  /* Vive aproximadamente 15 anios */
    float reproductionRate = 0.4;
    int speed = 8;
    /* Estrategia reproductiva K: pocos descendientes, mucho cuidado parental */
    reproductionStrategy = reproductionStrategy.K_SELECTED;
    diet = diet.CARNIVORE;  /* Cazador carnivoro */
    habitat = habitat.TERRESTRIAL;
    environmentalTolerance;
    /* Rango de temperatura tolerable: 5 grados a 35 grados */
    .temperature = [5, 35];
    .humidity = [30, 80];
    .altitude = [0, 4000];
}

/*
 * Definicion de la region del ecosistema
 * Parametros ambientales especificos
 */
region Bosque {
    temperature = 20;
    humidity = 70;
    altitude = 800;
    carryingCapacity = 200;  /* Maxima poblacion soportada */
    habitat = TERRESTRIAL;
}

/* Ecosistema completo integrado */
ecosystem Patagonia {
    region Bosque;  /* La unica region del ecosistema */
    species Puma;   /* La unica especie del ecosistema */
}
