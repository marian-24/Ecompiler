//Especie terrestre en region acuatica (mayor mortalidad)

species Puma = createSpecies {
    int lifespan = 15;
    float reproductionRate = 0.4;
    int speed = 8;
    reproductionStrategy = reproductionStrategy.K_SELECTED;
    diet = diet.CARNIVORE;
    habitat = habitat.TERRESTRIAL;
    environmentalTolerance;
    .temperature = [5, 35];
    .humidity = [30, 80];
    .altitude = [0, 4000];
}

region Lago {
    temperature = 15;
    humidity = 90;
    altitude = 200;
    carryingCapacity = 100;
    habitat = AQUATIC;
}

ecosystem Patagonia {
    region Lago;
    species Puma;
}

add 10 Puma to Patagonia.Lago;
simulate Patagonia for 20 generations;
log population of Puma in Patagonia.Lago;
