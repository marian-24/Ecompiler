//Cambio ambiental fijo en una generacion especifica

region Bosque {
    temperature = 20;
    humidity = 70;
    altitude = 800;
    carryingCapacity = 200;
    habitat = TERRESTRIAL;
}

ecosystem Patagonia {
    region Bosque;
}

on generation 50 in Patagonia.Bosque {
    temperature += 20;
    humidity -= 40;
}
