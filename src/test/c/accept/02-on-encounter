//on encounter con primitivas de modificación de atributos

species Puma = createSpecies {
    int lifespan = 15;
    float reproduction_rate = 0.4;
    int speed = 8;
    reproduction_strategy rep_strat = reproduction_strategy.k_selected;
    diet my_diet = diet.carnivore;
    habitat hab = habitat.terrestrial;
    environmental_tolerance env_tol;
    env_tol.temperature = [5, 35];
    env_tol.humidity = [30, 80];
    env_tol.altitude = [0, 4000];
}

species Guanaco = createSpecies {
    int lifespan = 8;
    float reproduction_rate = 0.5;
    int speed = 6;
    reproduction_strategy rep_strat = reproduction_strategy.r_selected;
    diet my_diet = diet.herbivore;
    habitat hab = habitat.terrestrial;
    environmental_tolerance env_tol;
    env_tol.temperature = [0, 40];
    env_tol.humidity = [20, 90];
    env_tol.altitude = [0, 5000];
}

region Bosque {
    temperature = 20;
    humidity = 70;
    altitude = 800;
    carrying_capacity = 200;
    habitat = habitat.terrestrial;
}

ecosystem Patagonia {
    region Bosque;
    species Puma;
    species Guanaco;
}

add 10 Puma to Patagonia.Bosque;
add 50 Guanaco to Patagonia.Bosque;

on encounter Puma with Guanaco in Patagonia.Bosque {
    if (Puma.speed > Guanaco.speed) {
        Guanaco.energy -= 40;
        Puma.energy += 40;
        if (Guanaco.energy <= 0) {
            remove Guanaco;
        }
    }
    else {
        Puma.energy -= 5;
        move Guanaco to Patagonia.Bosque;
    }
}