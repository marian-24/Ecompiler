//Ecosistema con comentarios de linea - valida que // comentarios se ignoran correctamente

// Definicion de una especie carnivora depredadora
species Puma = createSpecies {
    int lifespan = 15;
    float reproductionRate = 0.4;  // tasa de reproduccion moderada
    int speed = 8;  // depredador rapido
    reproductionStrategy = reproductionStrategy.K_SELECTED;  // estrategia K
    diet = diet.CARNIVORE;  // carnivoro
    habitat = habitat.TERRESTRIAL;  // terrestre
    environmentalTolerance;
    .temperature = [5, 35];  // tolera temperaturas templadas
    .humidity = [30, 80];  // rango de humedad
    .altitude = [0, 4000];  // hasta 4000 metros
}

// Definicion de la region geografica
region Bosque {
    temperature = 20;  // temperatura promedio
    humidity = 70;  // muy humedo
    altitude = 800;  // region montana baja
    carryingCapacity = 200;  // maximo 200 individuos
    habitat = TERRESTRIAL;
}

// Definicion del ecosistema completo
ecosystem Patagonia {
    region Bosque;  // incluye region bosque
    species Puma;  // incluye especie Puma
}
