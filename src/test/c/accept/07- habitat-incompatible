//Especie terrestre en región acuática (mayor mortalidad)

species Puma = createSpecies {
    int lifespan = 15;
    float reproduction_rate = 0.4;
    int speed = 8;
    reproduction_strategy rep_strat = reproduction_strategy.k_selected;
    diet my_diet = diet.carnivore;
    habitat hab = habitat.terrestrial;
    environmental_tolerance env_tol;
    env_tol.temperature = [5, 35];
    env_tol.humidity = [30, 80];
    env_tol.altitude = [0, 4000];
}

region Lago {
    temperature = 15;
    humidity = 90;
    altitude = 200;
    carrying_capacity = 100;
    habitat = habitat.aquatic;
}

ecosystem Patagonia {
    region Lago;
    species Puma;
}

add 10 Puma to Patagonia.Lago;
simulate Patagonia for 20 generations;
log population of Puma in Patagonia.Lago;
